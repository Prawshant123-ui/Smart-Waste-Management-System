// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url= env("DATABASE_URL")
}



enum Role {
  CITIZEN
  COLLECTOR
  ADMIN
}

enum BinStatus {
  NORMAL
  FULL
  OVERFLOWING
}

enum ComplaintStatus {
  PENDING
  APPROVED
  ASSIGNED
  RESOLVED
  REJECTED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  CRITICAL
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

enum CollectionStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String   @unique
  role      Role     @default(CITIZEN)
  createdAt DateTime @default(now())

  createdBins Bin[]        @relation("BinCreator")
  complaints  Complaint[]  @relation("CitizenComplaints")
  tasks       Collection[] @relation("CollectorTasks")
}

model Bin {
  id            String     @id @default(uuid())
  latitude      Float
  longitude     Float
  address       String
  capacity      Int
  status        BinStatus  @default(NORMAL)
  lastCollected DateTime?
  createdAt     DateTime   @default(now())

  createdBy   String
  creator     User         @relation("BinCreator", fields: [createdBy], references: [id])
  complaints  Complaint[]
  collections Collection[]
}

model Complaint {
  id          String            @id @default(uuid())
  image       String
  description String?
  priority    ComplaintPriority @default(MEDIUM)
  status      ComplaintStatus   @default(PENDING)
  createdAt   DateTime          @default(now())

  citizenId  String
  citizen    User        @relation("CitizenComplaints", fields: [citizenId], references: [id])
  binId      String?
  bin        Bin?        @relation(fields: [binId], references: [id])
  collection Collection?
}

model Vehicle {
  id            String        @id @default(uuid())
  vehicleNumber String        @unique
  driver        String
  fuelType      String
  status        VehicleStatus @default(AVAILABLE)
  createdAt     DateTime      @default(now())

  collections Collection[]
}

model Collection {
  id              String           @id @default(uuid())
  startTime       DateTime?
  endTime         DateTime?
  completionPhoto String?
  status          CollectionStatus @default(ASSIGNED)
  createdAt       DateTime         @default(now())

  collectorId String
  collector   User    @relation("CollectorTasks", fields: [collectorId], references: [id])
  vehicleId   String
  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])
  binId       String
  bin         Bin     @relation(fields: [binId], references: [id])

  complaintId String?    @unique
  complaint   Complaint? @relation(fields: [complaintId], references: [id])
}